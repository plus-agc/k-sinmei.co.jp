                fill="#fff"
                class="svg-elem"
                id="path"
              >
              </path>
              <path
                d="M348.62,385.72H435.7L482.07,8.53H394.99ZM477.55,12.53,432.16,381.72H353.14L398.53,12.53h79.02Z"
                fill="#fff"
                class="svg-elem"
              >
              </path>
              <path
                d="M845.57,253.95,671.96,8.53H596.2L549.26,385.72h87.08l29.98-246.57L841.05,385.72h75.78L963.18,8.53H876.1ZM958.66,12.53,913.27,381.72H843.1L669.57,136.84l-5.99-8.45-1.25,10.28L632.78,381.72H553.77L599.72,12.53h70.16L842.3,256.26l5.96,8.43,1.27-10.24L879.62,12.54h79.04Z"
                fill="#fff"
                class="svg-elem"
              >
              </path>
              <path
                d="M1373.33,8.53,1251.19,234.16,1186.72,8.53H1114.9L1007.46,385.72h87.08l57.69-225.08,66.16,225.08h32.8l120.44-225.06,2.27,225.06h87.08L1447.41,8.53Zm4.53,373.19-2.23-221.1-.16-15.62-7.37,13.77L1248.79,381.72h-27.41l-65.31-222.2-4.1-13.95-3.61,14.09-56.92,222.07h-78.68L1117.92,12.54h65.78l63.64,222.73,2.69,9.43,4.67-8.63L1375.71,12.54h67.84l13.28,369.19h-78.97Z"
                fill="#fff"
                class="svg-elem"
              >
              </path>
              <path
                d="M1551.23,385.72h210.36l9.04-73.53H1645.1l10.18-83.68h118.74l9.04-73.53H1664.32l9.05-72.95h123.28l9.04-73.51h-208.1ZM1801.17,12.53l-8.06,65.51H1669.84l-.44,3.51-9.05,72.95-.56,4.49h118.75l-8.06,65.53H1651.74l-.43,3.52-10.18,83.68-.55,4.48h125.53l-8.06,65.53h-202.3l45.39-369.19h200.03Z"
                fill="#fff"
                class="svg-elem"
              >
              </path>
              <path
                d="M1912.92,8.53l-46.37,377.19h87.08L2000,8.53Zm37.17,373.19h-79.02l45.39-369.19h79.02Z"
                fill="#fff"
                class="svg-elem"></path>
            </g>
          </svg>
        </div>
        <div class="top-main">
          <div class="top-image">
            <img src="/assets/images/top-hero.jpg" alt="工場・製造現場の様子" />
          </div>
        </div>
        <div class="top-tit">
          <p class="is-anim_one">もっとよいものを</p>
          <p class="is-anim_two">責任をもって</p>
          <p class="is-anim_three">作れる会社へ</p>
        </div>
      </div>
    </section>
    <section class="top-news">
      <div class="top-news-inner">
        <div class="top-news-main">
          <div class="top-news-tit">
            <p lang="en">news</p>
            <h2>お知らせ</h2>
          </div>
          <ul class="top-news-list">
            {
              latestNews.map((post) => (
                <li class="news-item">
                  <a href={`/news/${post.id}`}>
                    <div class="news-item-header" lang="ja">
                      <time datetime={post.publishedAt.slice(0, 10)}>
                        {post.publishedAt.slice(0, 10)}
                      </time>
                      <p>{post.category ?? "お知らせ"}</p>
                    </div>
                    <div class="news-item-main">
                      <p>{post.title}</p>
                      <img
                        src="/assets/images/arrow-blue.svg"
                        alt="矢印アイコン下向き青"
                      />
                    </div>
                  </a>
                </li>
              ))
            }
          </ul>
          <div class="top-news-link">
            <a href="/news">
              <p lang="en">read more</p>
              <img src="/assets/images/arrow-blue.svg" alt="矢印アイコン青" />
            </a>
          </div>
        </div>
      </div>
    </section>
    <section class="top-company">
      <div class="top-company-inner">
        <div class="top-company-main">
          <div class="top-company-main_half">
            <div class="top-company-tit">
              <p>鉄を創り、</p>
              <p>街を支え、</p>
              <p>未来を拓く。</p>
            </div>
            <div class="top-company-text">
              <p>長年の実績と確かな施工品質で地域社会の発展に貢献します。</p>
            </div>
            <div class="top-company-link">
              <a href="/company">
                <p lang="en">SINMEIについて</p>
                <img src="/assets/images/arrow.svg" alt="矢印アイコン" />
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
    <section class="top-services">
      <div class="top-services-inner">
        <div class="top-services-main">
          <div class="top-services-tit">
            <p lang="en">sinmeiについて</p>
            <h2>事業内容</h2>
          </div>
          <div class="top-services-text">
            <p>
              <span class="top-services-text_large">
                株式会社SINMEIは、国土交通大臣認定の最高位「Hグレード」を保有する鋼構造物のスペシャリスト集団です。
              </span>
              長年培った高度な技術力と厳格な品質管理体制により、東北エリアから首都圏の超高層ビル、大規模スタジアムに至るまで、都市の象徴となる数々のランドマークを支えてきました。
              設計・作図から工場製作、そして現場施工までを一貫して担う独自の機動力で、安全で揺るぎない社会インフラの構築に貢献し続けます。
            </p>
          </div>
          <div class="top-services-link">
            <a href="/company">
              <p lang="en">事業内容</p>
              <img src="/assets/images/arrow.svg" alt="矢印アイコン" />
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="top-recruit">
      <div class="top-recruit-inner">
        <div class="top-recruit-header">
          <img src="/assets/images/recruit-A.png" alt="社員画像01" />
          <img src="/assets/images/recruit-B.png" alt="社員画像02" />
          <img src="/assets/images/recruit-C.png" alt="社員画像03" />
          <img src="/assets/images/recruit-D.png" alt="社員画像04" />
          <img src="/assets/images/recruit-E.png" alt="社員画像05" />
        </div>
        <div class="top-recruit-main">
          <div class="top-recruit-catch">
            <p>現場を知り、<br />人を想う毎日が<br />誇れる仕事</p>
          </div>
          <div class="top-recruit-content">
            <p class="top-recruit-text">私たちと一緒に働いてみませんか</p>
            <div class="top-recruit-link">
              <a href="/recruit">
                <p lang="en">採用情報</p>
                <img src="/assets/images/arrow.svg" alt="矢印アイコン" />
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  path {
    fill: none;
    stroke: #fff;
    stroke-width: 2px;
    stroke-dasharray: 2800px;
  }
</style>
<script>
  import { gsap } from "gsap";
  import { TextPlugin } from "gsap/TextPlugin";
  gsap.registerPlugin(TextPlugin);

  // テキストアニメーション対象を初期化（SSRフォールバックをクリア）
  (document.querySelector(".is-anim_one") as HTMLElement).textContent = "";
  (document.querySelector(".is-anim_two") as HTMLElement).textContent = "";
  (document.querySelector(".is-anim_three") as HTMLElement).textContent = "";

  const svgPaths = document.querySelectorAll("svg path");

  // ヒーロー画像の初期状態を設定（拡大＋透明）
  gsap.set(".top-image img", { opacity: 0, scale: 1.08 });

  // ページ読み込み直後に画像・SVGを表示開始
  fadeInImage();

  svgPaths.forEach((path) => {
    (path as SVGPathElement).style.visibility = "visible";
  });
  gsap.fromTo(
    "svg path",
    { "stroke-dashoffset": "2800px" },
    { "stroke-dashoffset": "0", duration: 5, stagger: 0.2 },
  );

  gsap.to(".is-anim_one", {
    duration: 1,
    text: "もっとよいものを",
    ease: "none",
    delay: 0,
  });
  gsap.to(".is-anim_two", {
    duration: 1,
    text: "責任をもって",
    ease: "none",
    delay: 0.5,
  });
  gsap.to(".is-anim_three", {
    duration: 1,
    text: "作れる会社へ",
    ease: "none",
    delay: 1.0,
  });

  function fadeInImage() {
    // ヒーロー画像のみ対象（リクルート画像はIntersection Observerで制御）
    // フェードインしながら拡大状態から通常サイズへ縮小（Ken Burns逆効果）
    gsap.to(".top-image img", {
      duration: 1.8,
      opacity: 1,
      scale: 1,
      ease: "power2.out",
    });
  }

  // SP時のみリクルート画像を自動フェードスライダーとして動作させる
  if (window.matchMedia("(max-width: 943px)").matches) {
    const imgs = Array.from(
      document.querySelectorAll<HTMLImageElement>(".top-recruit-header img"),
    );
    if (imgs.length > 0) {
      let current = 0;
      imgs[current].classList.add("is-active");

      setInterval(() => {
        imgs[current].classList.remove("is-active");
        current = (current + 1) % imgs.length;
        imgs[current].classList.add("is-active");
      }, 3000);
    }
  }
</script>
